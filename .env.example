# Copy to .env and fill in. .env is gitignored.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_DATABASE=prompt_shield
MYSQL_USER=shield
MYSQL_PASSWORD=change-me-app

# --- Backend ---
SPRING_PROFILES_ACTIVE=prod
BACKEND_PORT=8080

# Anthropic — only required if you enable the LLM judge
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Audit log config
SHIELD_AUDIT_STORE_RAW=false

# --- Frontend ---
# Frontend nginx proxies /scan and /audit to the backend over the compose
# network, so no API base URL needs to be injected at build time.
FRONTEND_PORT=4200
